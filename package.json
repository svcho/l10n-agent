{
  "name": "l10n-agent",
  "version": "0.3.0",
  "description": "Local-first CLI for canonical mobile app localization workflows.",
  "type": "module",
  "bin": {
    "l10n-agent": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf coverage dist",
    "dev": "tsx src/cli/index.ts",
    "prepare": "husky",
    "repo:public-check": "npm run secrets:scan && npm pack --dry-run",
    "secrets:scan": "secretlint \"**/*\"",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "cli",
    "i18n",
    "l10n",
    "localization",
    "typescript"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.1",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.2",
    "@types/node": "^24.7.2",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "secretlint": "^11.3.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
